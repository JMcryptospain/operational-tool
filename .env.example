# Supabase
# Get these from Project Settings → API in the Supabase dashboard.
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_...
SUPABASE_SERVICE_ROLE_KEY=sb_secret_...

# Direct Postgres connection (Session pooler, IPv4-compatible).
# From Supabase Dashboard → Connect → Session pooler.
SUPABASE_DB_URL=postgresql://postgres.[project-ref]:[password]@aws-X-[region].pooler.supabase.com:5432/postgres

# --- Resend (transactional emails) ---
# API key from https://resend.com/api-keys
RESEND_API_KEY=re_...
# Friendly From header. Domain must be verified in Resend.
EMAIL_FROM=Taiko Launchpad <noreply@launchpad.taiko.xyz>
# Origin URL used to build absolute links inside email bodies.
APP_URL=https://operational-tool.vercel.app

# --- Cron ---
# Vercel Cron sends Authorization: Bearer <CRON_SECRET> on every request.
# Generate any long random string and set it both here and in the Vercel
# project env vars. Local dev skips this check automatically.
CRON_SECRET=replace_with_long_random_string

# --- PostHog ---
# Single shared PostHog project; apps distinguish themselves via a slug
# passed on posthog.group('app', '<slug>') and/or as a property.
NEXT_PUBLIC_POSTHOG_PROJECT_TOKEN=phc_...
NEXT_PUBLIC_POSTHOG_HOST=https://eu.posthog.com
POSTHOG_PERSONAL_API_KEY=phx_...
POSTHOG_PROJECT_ID=123456
